pan><span class="mtk6">64</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk6">3</span><span class="mtk14">,</span><span class="mtk1">&nbsp;activation=</span><span class="mtk5">'relu'</span><span class="mtk14">),</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;layers.MaxPooling2D</span><span class="mtk14">(),</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;layers.Flatten</span><span class="mtk14">(),</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;layers.Dense</span><span class="mtk14">(</span><span class="mtk6">128</span><span class="mtk14">,</span><span class="mtk1">&nbsp;activation=</span><span class="mtk5">'relu'</span><span class="mtk14">),</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;layers.Dropout</span><span class="mtk14">(</span><span class="mtk6">0.4</span><span class="mtk14">),</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;layers.Dense</span><span class="mtk14">(</span><span class="mtk6">10</span><span class="mtk14">,</span><span class="mtk1">&nbsp;activation=</span><span class="mtk5">'softmax'</span><span class="mtk14">)</span></span><br><span><span class="mtk14">])</span></span><br><span><span></span></span><br><span><span class="mtk1">aug_cnn_model.</span><span class="mtk17">compile</span><span class="mtk14">(</span><span class="mtk1">optimizer=</span><span class="mtk5">'adam'</span><span class="mtk14">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;loss=</span><span class="mtk5">'sparse_categorical_crossentropy'</span><span class="mtk14">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;metrics=</span><span class="mtk14">[</span><span class="mtk5">'accuracy'</span><span class="